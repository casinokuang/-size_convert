{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "updateContentCommand": "pip3 install -r requirements.txt && pip3 install streamlit",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
    }
  },
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openBrowser" 
    }
  },
  // 使用这个属性来确保容器启动后命令能正确触发
  "postStartCommand": "python3 -m streamlit run streamlit_app.py --server.enableCORS false"
}
